<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Non-sandboxed direct-distribution build (not App Store) -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Network: Claude API calls + local WebSocket terminal server -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File system: user-opened project files -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>

    <!-- Apple Events for shell automation -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Hardened Runtime: WebKit JIT only (allow-jit is sufficient) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Required for window-vibrancy and Tauri private APIs that load
         Apple-signed private frameworks. Can be removed once window-vibrancy
         is confirmed to work without it on all supported macOS versions. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
